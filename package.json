{
  "name": "ca-surfplanning-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/bundle-mcp.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test 'tests/*.test.ts' 'app/**/*.test.ts' 'app/**/*.test.tsx' 'lib/**/*.test.ts' 'lib/**/*.test.tsx'",
    "test:integration": "SURFPLANNER_INTEGRATION=1 tsx --test tests/integration/*.integration.test.ts",
    "smoke": "SURFPLANNER_SMOKE=1 node --env-file-if-exists=.env.local --test-force-exit --import tsx --test tests/integration/plan-pipeline.smoke.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-google-maps": "^0.6.2",
    "@vercel/kv": "^3.0.0",
    "ai": "^6.0.174",
    "mapbox-gl": "^3.23.0",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "open-meteo-mcp-server": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.1",
    "redis": "^5.12.1",
    "workflow": "^4.2.4",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
