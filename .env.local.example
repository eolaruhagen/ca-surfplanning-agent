# Copy to .env.local and fill in values.

# Vercel AI Gateway (model routing — replaces direct Anthropic API)
# Local dev: get a key from https://vercel.com/dashboard → AI Gateway → Keys
# On a deployed Vercel project this is unnecessary; auth flows via OIDC automatically.
AI_GATEWAY_API_KEY=vck_...

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...
GOOGLE_MAPS_API_KEY=AIza...

# KV (local dev — points at the redis service in docker-compose.yml)
REDIS_URL=redis://localhost:6379

# KV (production — Vercel injects these automatically when KV/Upstash is provisioned)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
